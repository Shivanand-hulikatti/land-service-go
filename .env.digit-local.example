# Use with run-land-noc-deps.sh (PG_PORT=5433, local MDMS/user/location).
#   cp .env.digit-local.example .env
#
# IMPORTANT: Stop Java land-services on port 8199 before starting land-services-go
# (both use the same port and context path).

LAND_SERVER_PORT=8199
LAND_SERVER_CONTEXTPATH=/land-services

# Postgres from digit-postgres container (PG_PORT=5433)
LAND_DATABASE_HOST=localhost
LAND_DATABASE_PORT=5433
LAND_DATABASE_NAME=testing_changes
LAND_DATABASE_USER=postgres
LAND_DATABASE_PASSWORD=postgres

# Redpanda/Kafka from digit-kafka container
LAND_KAFKA_BOOTSTRAPSERVERS=localhost:9092
LAND_KAFKA_SAVELANDINFOTOPIC=save-landinfo
LAND_KAFKA_UPDATELANDINFOTOPIC=update-landinfo

# Core services from run-land-noc-deps.sh
LAND_EGOV_USER_HOST=http://localhost:8081
LAND_EGOV_LOCATION_HOST=http://localhost:8082
LAND_EGOV_MDMS_HOST=http://localhost:8094
LAND_EGOV_LOCALIZATION_HOST=http://localhost:8087
