      "name": "Health",
      "item": [
        {
          "name": "GET health — UP",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json", "description": "Required" }
            ],
            "url": "{{baseUrl}}/health",
            "description": "Liveness check. Expect 200 when process is up."
          },
          "response": [
            {
              "name": "200 — UP (DB + Kafka connected)",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"UP\",\n  \"service\": \"land-services-go\",\n  \"components\": {\n    \"database\": \"UP\",\n    \"kafka\": \"UP\"\n  }\n}"
            },
            {
              "name": "503 — DEGRADED (DB or Kafka down)",
              "status": "Service Unavailable",
              "code": 503,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"status\": \"DEGRADED\",\n  \"service\": \"land-services-go\",\n  \"components\": {\n    \"database\": \"DOWN\",\n    \"kafka\": \"DOWN\"\n  }\n}"
            }
          ]
        }
      ]
