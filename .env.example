# Copy to .env on your Ubuntu host and adjust for local DIGIT stack.
#   cp .env.example .env
#
# All variables use the LAND_ prefix (Viper maps nested yaml keys with underscores).

LAND_SERVER_PORT=8199
LAND_SERVER_CONTEXTPATH=/land-services

# PostgreSQL (land DB — same as Java land-services)
LAND_DATABASE_HOST=localhost
LAND_DATABASE_PORT=5433
LAND_DATABASE_NAME=land_services
LAND_DATABASE_USER=postgres
LAND_DATABASE_PASSWORD=postgres

# Kafka (persister topics for create/update)
LAND_KAFKA_BOOTSTRAPSERVERS=localhost:9092
LAND_KAFKA_SAVELANDINFOTOPIC=save-landinfo
LAND_KAFKA_UPDATELANDINFOTOPIC=update-landinfo

# Local egov services (typical DIGIT local setup ports)
LAND_EGOV_USER_HOST=http://localhost:8081
LAND_EGOV_LOCATION_HOST=http://localhost:8082

# MDMS — use dev gateway or your local MDMS host
LAND_EGOV_MDMS_HOST=https://dev.digit.org

# Optional: custom config file path
# LAND_CONFIG_FILE=/path/to/app.yaml
